<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:local="using:VibePanel"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="VibePanel.MainView">
	<local:VibePanel>
		<Rectangle Width="80" Height="80" Fill="White" x:Name="MainRectangle" local:VibePanel.X="1" local:VibePanel.Y="-1"/>
		<StackPanel Orientation="Vertical">
			<StackPanel Orientation="Horizontal" MinWidth="250" Margin="250,0,0,0">
				<TextBlock Text="X: "/>
				<TextBlock x:Name="XTextBlock"/>
			</StackPanel>
			<StackPanel Orientation="Horizontal" MinWidth="250" Margin="250,0,0,0">
				<TextBlock Text="Y: "/>
				<TextBlock x:Name="YTextBlock"/>
			</StackPanel>
		</StackPanel>

		<Button Width="50" Height="50" local:VibePanel.Y="-0.25" local:VibePanel.X="0" x:Name="UpButton" Click="UpButton_Click">
			<TextBlock Text="↑" VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center"/>
		</Button>

		<Button Width="50" Height="50" local:VibePanel.Y="0" local:VibePanel.X="0.25" x:Name="RightButton" Click="RightButton_Click">
			<TextBlock Text="→" VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center"/>
		</Button>

		<Button Width="50" Height="50" local:VibePanel.Y="0" local:VibePanel.X="-0.25" x:Name="LeftButton" Click="LeftButton_Click">
			<TextBlock Text="←" VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center"/>
		</Button>

		<Button Width="50" Height="50" local:VibePanel.Y="0.25" local:VibePanel.X="0" x:Name="DownButton" Click="DownButton_Click">
			<TextBlock Text="↓" VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center"/>
		</Button>

	</local:VibePanel>
</UserControl>
